{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "public/**",   "use": "@vercel/static" }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1",
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Access-Control-Allow-Methods": "GET,POST,DELETE,OPTIONS",
        "Access-Control-Allow-Headers": "Content-Type,x-admin-secret"
      }
    },
    { "src": "/admin",         "dest": "/public/admin.html" },
    { "src": "/sw.js",         "dest": "/public/sw.js",
      "headers": { "Cache-Control": "no-cache, no-store, must-revalidate", "Service-Worker-Allowed": "/" }
    },
    { "src": "/manifest.json", "dest": "/public/manifest.json",
      "headers": { "Content-Type": "application/manifest+json", "Access-Control-Allow-Origin": "*" }
    },
    { "src": "/icons/(.*)",    "dest": "/public/icons/$1" },
    { "src": "/(.*)",          "dest": "/public/$1" }
  ]
}
